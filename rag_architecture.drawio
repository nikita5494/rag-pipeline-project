<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="RAG Architecture">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="2" value="PDF Documents&#xa;(ISO, AUTOSAR, ADAS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="240" y="20" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="3" value="Document Loader&#xa;(PyPDFLoader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="240" y="120" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="4" value="Text Chunking&#xa;(RecursiveCharacterTextSplitter)&#xa;chunk=800 / overlap=100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="240" y="220" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="5" value="Embedding Layer&#xa;(OpenAI - text-embedding-3-small)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="240" y="340" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="6" value="Vector Database&#xa;(ChromaDB - Persistent Store)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="240" y="450" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="7" value="Retrieval + QA Layer&#xa;(Next Step)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="560" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="10" style="endArrow=block;" edge="1" parent="1" source="2" target="3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="11" style="endArrow=block;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="12" style="endArrow=block;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="13" style="endArrow=block;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="14" style="endArrow=block;" edge="1" parent="1" source="6" target="7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>